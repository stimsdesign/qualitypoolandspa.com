---
// Import Config
import { siteConfig } from "../siteConfig";
// Import Assets
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
// Import Styles
import "../assets/css/styles.css";
// Import Components
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import MobileNav from "../components/navigation/MobileNav.astro";

// Import Symbols > Icons
const iconFiles = import.meta.glob("../icons/{Whistle,Skimmer,Swimmer,Umbrella,Cross,Hamburger,MobilePhone,ArrowLeft,ArrowRight,Mail,Messenger,Logo}.astro", { eager: true });
const iconComponents = Object.values(iconFiles).map((module: any) => module.default);

// Import Symbols > Logos
const logoFiles = import.meta.glob("../assets/images/logo/*.astro", { eager: true });
const logoComponents = Object.values(logoFiles).map((module: any) => module.default);

const svgSymbols = [
    ...iconComponents,
    ...logoComponents,
];

interface Props {
    title?: string;
    description?: string;
    keywords?: string;
    author?: string;
    ogImage?: string;
    favicon?: string;
}

const {
    title = siteConfig.title,
    description = siteConfig.description,
    keywords = siteConfig.keywords,
    author = siteConfig.author,
    ogImage = siteConfig.ogImage,
    favicon = "/favicon.svg",
} = Astro.props;
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="keywords" content={keywords} />
        <meta name="author" content={author} />
        <meta name="generator" content={Astro.generator} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://www.qualitypoolandspa.com" />
        <title>{title}</title>
        <link rel="icon" href={favicon} type="image/x-icon" />
        <link rel="preconnect" href="https://maps.google.com" />
        <link rel="preconnect" href="https://elfsightcdn.com" />
        <Font cssVariable="--font-raleway" preload />
        <Font cssVariable="--font-quicksand" preload />
        <Font cssVariable="--font-roboto-condensed" preload />
        <ClientRouter />
    </head>
    <body>
        <Header />
        <slot />
        <Footer />
        <MobileNav />
        <svg xmlns="http://www.w3.org/2000/svg" class="hidden" aria-hidden="true">
            {svgSymbols.map((Symbol) => (
                <Symbol />
            ))}
        </svg>
        <script is:inline src="/js/scripts.js" defer></script>
        <script>
            import { functionFuzzyLoad } from "../assets/scripts/FuzzyLoad.js";
            
            // Run on initial load and client-side routing transitions
            document.addEventListener("astro:page-load", () => {
                functionFuzzyLoad();
            });
        </script>
    </body>
</html>