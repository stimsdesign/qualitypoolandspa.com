---
// Import Config
import { siteConfig } from "../siteConfig";
// Import Assets
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
// Import Styles
import "../assets/css/styles.css";
// Import Components
import HomeHeader from "../components/layout/HomeHeader.astro";
import Footer from "../components/layout/Footer.astro";
import MobileNav from "../components/navigation/MobileNav.astro";
import RequestForm from "../components/sections/RequestForm.astro";

// Import Symbols > Icons
// const iconFiles = import.meta.glob("../icons/{Whistle,Skimmer,Swimmer,Umbrella,Cross,Hamburger,MobilePhone,ArrowLeft,ArrowRight,Mail,Logo}.astro", { eager: true });
const iconFiles = import.meta.glob("../icons/{Whistle,Skimmer,Swimmer,Umbrella,Cross,Hamburger,MobilePhone,ArrowLeft,ArrowRight,Mail,Logo}.astro", { eager: true });
const iconComponents = Object.values(iconFiles).map((module: any) => module.default);

// Import Symbols > Logos
const logoFiles = import.meta.glob("../assets/images/logo/*.astro", { eager: true });
const logoComponents = Object.values(logoFiles).map((module: any) => module.default);

// Import Symbols > HomeHero.astro
const badgeFiles = import.meta.glob("../assets/images/badges/*.astro", { eager: true });
const badgeComponents = Object.values(badgeFiles).map((module: any) => module.default);

// Imports Symbols > ServiceArea.astro
const brandFiles = import.meta.glob("../assets/images/brands/*.astro", { eager: true });
const brandComponents = Object.values(brandFiles).map((module: any) => module.default);

const svgSymbols = [
    ...iconComponents,
    ...logoComponents,
    ...badgeComponents,
    ...brandComponents
];

interface Props {
    title?: string;
    description?: string;
    keywords?: string;
    author?: string;
    ogImage?: string;
    favicon?: string;
}

const {
    title = siteConfig.title,
    description = siteConfig.description,
    keywords = siteConfig.keywords,
    author = siteConfig.author,
    ogImage = siteConfig.ogImage,
    favicon = "/favicon.svg",
} = Astro.props;
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="keywords" content={keywords} />
        <meta name="author" content={author} />
        <meta name="generator" content={Astro.generator} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://www.qualitypoolandspa.com" />
        <title>{title}</title>
        <link rel="icon" href={favicon} type="image/x-icon" />
        <Font cssVariable="--font-raleway" preload />
        <Font cssVariable="--font-quicksand" preload />
        <Font cssVariable="--font-roboto-condensed" preload />
        <ClientRouter />
    </head>
    <body>
        <HomeHeader />
        <main>
            <slot />
        </main>
        <Footer />
        <MobileNav />
        <RequestForm />
        <svg xmlns="http://www.w3.org/2000/svg" class="hidden" aria-hidden="true">
            {svgSymbols.map((Symbol) => (
                <Symbol />
            ))}
        </svg>
        <script is:inline src="/js/scripts.js" defer></script>
        <script>
            import { functionFuzzyLoad } from "../assets/scripts/FuzzyLoad.js";
            
            // Prevent FOUT (Flash of Unstyled Text) Layout Shift Animations
            function initFonts() {
                Promise.all([
                    document.fonts.load("900 1em 'Roboto Condensed'"),
                    document.fonts.load("900 1em 'Raleway'"),
                ]).then(() => {
                    document.documentElement.classList.add('fonts-loaded');
                }).catch(() => {
                    document.documentElement.classList.add('fonts-loaded');
                });
            }

            // Defer heavy animations until after LCP
            function initCaustics() {
                if (document.readyState === 'complete') {
                    setTimeout(() => document.documentElement.classList.add('enable-caustics'), 100);
                } else {
                    window.addEventListener('load', () => {
                        setTimeout(() => document.documentElement.classList.add('enable-caustics'), 100);
                    });
                }
            }

            // Run on initial load and client-side routing transitions
            document.addEventListener("astro:page-load", () => {
                functionFuzzyLoad();
                initFonts();
                initCaustics();
            });
        </script>
    </body>
</html>
