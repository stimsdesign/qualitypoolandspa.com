---
// Assets
import { Image } from "astro:assets";
import { siteConfig } from "../siteConfig";
// Components
import Template from "../layouts/ContentPage.astro";
import Main from '../components/layout/Main.astro';
import PageHeading from '../components/elements/PageHeading.astro';
import GoogleReviews from "../components/elements/GoogleReviews.astro";
import Button from "../components/elements/Button.astro";
import RequestForm from "../components/sections/RequestForm.astro";
// Images
import RMGAcert from "../assets/images/rmga-logo.png";
---

<Template title={`Our Services | ${siteConfig.title}`} description={`Quality Pool and Spa is a family-owned and operated business serving Salt Lake City, Utah, and the surrounding areas. We are dedicated to providing our customers with the highest quality pool and spa services.`}>
	<Main id="about-page">
		<PageHeading background="/images/caustics-banner.webp" fuzzy="/images/caustics-banner-fuzzy.webp">About Us</PageHeading>
		<div class="content-wrapper">
			<div class="content-story">
				<Image src={RMGAcert} alt="RMGA Certified" />
				<div>
					<h2>Our Story</h2>
					<p>For 30 years, <strong>Quality Pool & Spa</strong> has been the trusted name in aquatic care across the Wasatch Front. We believe your backyard should be a sanctuary, not a source of stress. Based in South Salt Lake, we are a dedicated team of <strong>pool and spa professionals</strong> passionate about keeping Utah swimming. We understand the unique challenges that our local climate presents—from the scorching summer sun to the deep freezes of a mountain winter. That’s why we’ve built our three-decade legacy on providing specialized, year-round care that protects your investment and maximizes your relaxation.</p>
				</div>
			</div>
			<div class="content-expertise">
				<h2><span class="electric">30 Years</span> of Local Expertise</h2>
				<p>Unlike seasonal companies that pack up when the leaves fall, we are true year-round aquatic specialists with <strong>30 years of proven experience</strong>. During the peak of summer, our technicians are out keeping water crystal clear, balancing chemistry, and ensuring your equipment is running at peak efficiency. When the snow flies, we shift gears to meticulous pool winterization and dedicated hot tub diagnostics. Whether you are down in the Salt Lake valley or up in the high elevations of Park City, we bring elite, time-tested service right to your backyard.</p>
			</div>
			<div class="content-reviews">
				<h2>Customer Reviews</h2>
				<GoogleReviews />
			</div>
			<div class="content-why">
				<h2>Why Choose Us</h2>
				<ul>
					<li><strong>Decades of Experience:</strong> With 30 years in business, we know Utah water. From calcium scaling to freeze damage, we understand exactly what your pool and spa need to thrive in our specific climate.</li>
					<li><strong>Comprehensive Care:</strong> We don't just clean pools. From advanced electrical diagnostics and boiler repairs to complete plumbing overhauls, our highly trained technicians handle the complex jobs others won't touch.</li>
					<li><strong>Dependable Partnership:</strong> When you hire Quality Pool & Spa, you are getting a dedicated partner backed by decades of local trust and BBB accreditation. We show up on time, communicate clearly, and do the job right the first time.</li>
				</ul>
			</div>
			<div class="content-mission">
				<h2>Our Mission</h2>
				<p>Our mission is simple: to provide unparalleled, stress-free pool and spa management so you can focus on making memories. We handle the heavy lifting, the precise chemistry, and the complex repairs, delivering crystal clear water and total peace of mind in every season.</p>
			</div>
		</div>
		<div class="content-cta">
			<h2 class="electric">Ready to experience the Quality Pool & Spa difference? Contact us today for a free quote.</h2>
			<Button class="wave request-form-trigger">Request a Quote</Button>
		</div>
	</Main>
</Template>

<RequestForm />


<style>


.content-wrapper {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 4cqi;
	align-items: top;
	margin: 0 auto;
}

@media (max-width: 769px) {
	.content-wrapper {
		grid-template-columns: 1fr;
		padding-top: 5cqi;
	}
}

	.content-left,
	.content-right {
		padding: 2cqi;
	}

	.content-reviews {
		grid-column: 1 / -1;
		overflow: hidden;
	}

	@media (max-width: 769px) {
		.content-reviews {
			margin-bottom: 2em;
		}
	}

	.content-story {
		display: grid;
		grid-template-columns: 200px 1fr;
		align-items: top;
		margin: 0 auto;
		gap: 2cqi;
	}

	.content-story img {
		width: 100%;
		height: auto;
	}

	@media (max-width: 769px) {
		.content-story {
			grid-template-columns: 1fr;
		}

		.content-story img {
			width: 50%;
			height: auto;
			margin: 0 auto 2cqi;
		}

		.content-story h2 {
			display: none;
		}
	}

	.content-wrapper h2 span {
		font-family: var(--font-roboto-condensed);
	}

	@media (max-width: 769px) {
		.content-wrapper h2 {
			margin-bottom: .5em;
			text-align: center;
		}
	}

	.content-why ul {
		list-style: none;
		padding: 0;
	}

	.content-why ul li {
		margin-bottom: .5em;
	}

	@media (max-width: 769px) {
		.content-why ul li {
			text-align: center;
		}
	}

	.content-mission p {
		font-size: var(--size-lg);
		font-style: italic;
		color: var(--color-secondary-dark);
	}

	@media (max-width: 769px) {
		.content-wrapper p {
			text-align: center;
		}
	}

	.content-cta {
		margin-top: 4cqi;
		padding-bottom: 4cqi;
		text-align: center;
	}

	.content-cta h2 {
        font-size: var(--size-xl);
        font-weight: 700;
        text-transform: uppercase;
		margin-bottom: 2rem;
	}
</style>
