---
import { siteConfig } from "../siteConfig";
import Template from "../layouts/ContentPage.astro";
import Main from '../components/layout/Main.astro';
import PageHeading from '../components/elements/PageHeading.astro';
import Button from '../components/elements/Button.astro';
---

<Template title={`404 - Page Not Found | ${siteConfig.title}`} description={`Sorry, the page you are looking for does not exist on ${siteConfig.brand}. Please check the URL or return to the homepage.`}>
	<Main id="fourofour">
		<PageHeading>
			<h1>Page Not Found</h1>
		</PageHeading>
		<p>Sorry, the page you are looking for does not exist.</p>
		<Button href="/" class="wave">Return to Homepage</Button>
	</Main>
</Template>

