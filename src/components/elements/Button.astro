---
interface Props {
    href?: string;
    id?: string;
    margin?: string;
    bookmark?: boolean;
    type?: string;
    class?: string;
    target?: string;
}

const { 
    href = "#", 
    id, 
    margin, 
    bookmark = false, 
    type = "anchor", 
    class: className = "",
    target
} = Astro.props;

const resolvedHref = href.trim() === "" ? "#" : href;
const trimmedClass = className.trim();
const isWave = trimmedClass.split(/\s+/).includes('wave');

const slotHtml = await Astro.slots.render('default');

// Prepare attributes to avoid empty ones
const attributes = {
    id: id || undefined,
    class: `button${bookmark ? " bookmark-button" : ""}${trimmedClass ? ` ${trimmedClass}` : ""}`,
    style: margin ? `margin: ${margin};` : undefined,
    target: target || undefined,
};
---

{
    type === "anchor" ? (
        <a href={resolvedHref} {...attributes}>
            <Fragment set:html={slotHtml} />
            {isWave && <span><Fragment set:html={slotHtml} /></span>}
        </a>
    ) : (
        <button type={type === "submit" ? "submit" : "button"} {...attributes}>
            <Fragment set:html={slotHtml} />
            {isWave && <span><Fragment set:html={slotHtml} /></span>}
        </button>
    )
}