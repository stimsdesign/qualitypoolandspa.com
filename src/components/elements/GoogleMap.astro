---
import { siteConfig } from "../../siteConfig";

// Construct the full address from site configuration
const address = `${siteConfig.addressLine1}, ${siteConfig.city}, ${siteConfig.state} ${siteConfig.postalCode}`;

// Encode the address and brand name for the URL query
const encodedQuery = encodeURIComponent(`${siteConfig.brand}, ${address}`);

// Google Maps Embed URL (No API key required for basic embed)
// Using z=10 provides a regional zoom level that nicely encompasses the Wasatch Front
const mapUrl = `https://maps.google.com/maps?width=100%25&height=100%25&hl=en&q=${encodedQuery}&t=&z=10&ie=UTF8&iwloc=B&output=embed`;
---

<div class="google-map-container">
    <iframe 
        src={mapUrl}
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade"
        title={`Google Map showing service area for ${siteConfig.brand}`}
    ></iframe>
</div>

<style>
    .google-map-container {
        width: 100%;
        height: 100%;
        overflow: hidden;
        background-color: #e0e0e0;
        position: relative;
        z-index: 99; /* Ensure it stays above background elements */
    }

    @media (max-width: 769px) {
        .google-map-container {
            min-height: 350px;
        }
    }

    iframe {
        border: none;
        width: 100%;
        height: 100%;
        display: block;
        position: absolute;
        top: 0;
        left: 0;
        background: transparent;
    }
</style>
