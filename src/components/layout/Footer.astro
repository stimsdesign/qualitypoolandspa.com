---

import { siteConfig } from "../../siteConfig";
const linksTitle = "Quick Links";
const links = [
    { name: "Home", href: "/", icon: null },
    { name: "Contact", href: "/contact.html", icon: null },
    { name: "About", href: "/about.html", icon: null },
    { name: "Services", href: "/services.html", icon: null },
];
const extrasTitle = "Credentials";
const extras = [
    { name: "A+ Certified by BBB", href: "https://www.bbb.org/us/ut/south-salt-lake/profile/pool-maintenance/quality-pool-spa-1166-2007823", icon: null },
];
---
<footer>
    <div class="footer-grid">
        <div class="footer-col brand-col">
            <svg viewBox="0 0 1184.82 543.66"><use href="#quality-pool-and-spa-white-logo" /></svg>
            <p class="brand-mission">{siteConfig.mission}</p>
            <div class="social-links">
                {siteConfig.socialLinks.map((link) => (
                    <a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={link.name}><link.icon /></a>
                ))}
            </div>
        </div>
        <div class="footer-col link-col">
            <h5>{linksTitle}</h5>
            <ul class="footer-links">
                {links.map((link) => (
                    <li><a href={link.href}>{link.name}{link.icon && <link.icon />}</a></li>
                ))}
            </ul>
        </div>
        <div class="footer-col link-col">
            <h5>{extrasTitle}</h5>
            <ul class="footer-links">
                {extras.map((link) => (
                    <li><a href={link.href} target="_blank" rel="noopener noreferrer">{link.name}{link.icon && <link.icon />}</a></li>
                ))}
            </ul>
        </div>
        <div class="footer-col extras-col">
            <h5>Quick Info</h5>
            <p><strong>Quality Pool & Spa</strong><br>{siteConfig.addressLine1} {siteConfig.addressLine2}<br>{siteConfig.city}, {siteConfig.state} {siteConfig.postalCode}</p>
            <p><strong>Operating Hours</strong><br>{siteConfig.hoursOfOperation}<br>{siteConfig.hoursOfOperationWeekend}</p>
            <p><strong>Phone</strong><br>{siteConfig.prettyTelephone}</p>
            <p><strong>Email</strong><br>{siteConfig.email}</p>
        </div>
    </div>
    <div class="footer-copy">
        <p class="copyright">©{new Date().getFullYear()} {siteConfig.company} <span>Quality is Our Specialty</span></p>
    </div>
</footer>

<style is:global>
    footer {
        display: flex;
        padding: 0 4cqi;
        flex-direction: column;
        position: relative;
        color: var(--color-foreground-lighter);
        background: linear-gradient(to bottom, var(--color-primary), var(--color-primary-light));
    }

    .footer-grid {
        width: calc(100% - 3cqi);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1.5fr;
        gap: 4cqi;
    }

    /* Brand Column */
    .brand-col {
        display: flex;
        flex-direction: column;
        gap: 1.5cqi;
    }

    .brand-col svg {
        max-width: 300px;
        width: fit-content;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .brand-mission {
        max-width: 35ch;
    }

    .social-links {
        display: flex;
        gap: 1.25cqi;
        text-align: center;
    }

    .social-links svg {
        color: var(--color-secondary-light);
        transition:
            color 0.3s ease,
            transform 0.3s ease;
        width: 35px;
        height: 35px;
    }

    .social-links svg:hover {
        color: var(--color-accent-light);
        transform: translateY(-3px);
    }


    /* Links */
    .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75cqi;
    }

    .footer-links a {
        color: var(--color-secondary-light);
        text-decoration: none;
        transition:
            color 0.3s ease,
            padding-left 0.3s ease;
        font-size: var(--size-lg);
        display: block;
    }

    .footer-links a:hover {
        color: var(--color-secondary-lighter);
        padding-left: 5px;
    }



    /* Bottom Bar */
    .footer-copy {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        margin: 2cqi 0;
    }   .footer-copy p {
        margin: 0;
        text-align: center;
        white-space: nowrap;
    }

    .footer-copy span {
        display: inline-block;
        margin-left: 1cqi;
        padding-left: 1cqi;
        border-left: 1px solid var(--color-secondary-light);
    }

    /* Responsive */
    @media (max-width: 1200px) {
        .footer-grid {
            grid-template-columns: 1.5fr 1fr 1fr;
        }
        .extras-col {
            grid-column: span 3;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2cqi;
        }
    }

    @media (max-width: 767px) {
        .footer-grid {
            grid-template-columns: 1fr 1fr;
            text-align: center;
        }

        .footer-col {
            margin-bottom: 2rem;
        }

        .logo-area {
            width: auto;
        }

        .brand-col {
            grid-column: span 2;
            text-align: center;
        }

        .brand-col svg {
            margin: 0 auto 1rem;
        }

        .brand-mission {
            max-width: 100%;
        }

        .extras-col {
            grid-column: span 2;
            display: block; /* Remove the 3-column grid for mobile */
            text-align: center;
        }

        .social-links {
            justify-content: center;
            gap: 5cqi;
        }

        .footer-copy p {
            white-space: normal;
        }

        .footer-copy span {
            display: block;
            margin-left: 0;
            padding-left: 0;
            border-left: none;
            margin:0 0 5cqi;
        }
    }

    @media (max-width: 500px) {
        .footer-grid {
            grid-template-columns: 1fr;
            gap: 3cqi;
        }
        .brand-col, .link-col, .extras-col {
            grid-column: span 1;
        }
    }
</style>