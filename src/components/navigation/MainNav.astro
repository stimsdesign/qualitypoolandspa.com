---
import { siteConfig } from "../../siteConfig";
const links = [
    { name: "Home", href: "/", icon: null },
    { name: "Contact", href: "/contact.html", icon: null },
];
---

<nav id="main-nav">
    <ul>
        {
            links.map((link) => (
                <li><a href={link.href}>{link.name}{link.icon && <link.icon />}</a></li>
            ))
        }
        <li>
            <a href={`tel:${siteConfig.telephone}`} aria-label={`Call Today ${siteConfig.prettyTelephone}`}>{siteConfig.prettyTelephone}</a>
        </li>
    </ul>
</nav>

<style is:global>

    #main-nav {
        width: 100%;
        height: 60px;
        background: linear-gradient(to right, var(--color-primary), var(--color-primary-lighter));
        border-bottom: solid 2px var(--color-accent);
    }

    #main-nav ul {
        display: flex;
        justify-content: left;
        align-items: center;
        height: 100%;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    #main-nav li a {
        color: var(--color-foreground);
        text-decoration: none;
        font-size: 1.2rem;
        padding: 0 15px;
        transition: color 0.3s ease;
    }

    @media (max-width: 769px) {
        nav#main-nav {display: none !important;}
    }
</style>