---
// Assets
import { siteConfig } from "../../siteConfig";
// Links
const links = [
    { name: "Our Services", href: "/services.html", icon: '#icon-skimmer', viewBox: '0 0 800 800' },
    { name: "Request an Opening", href: "/opening.html", icon: '#icon-umbrella', viewBox: '0 0 800 800' },
    { name: "Join Our Team", href: "/jobs.html", icon: '#icon-swimmer', viewBox: '0 0 128 128' },
    { name: "Contact Us", href: "/contact.html", icon: '#icon-whistle', viewBox: '0 0 512 512' },
    { name: "About Us", href: "/about.html", icon: '#icon-logo', viewBox: '0 0 800 800' },
];
---
<div class="mobile-nav-container">
    <a id="mobile-nav__icon" href="/" aria-label="Return to Quality Pool and Spa home"><svg viewBox="0 0 417 531.01"><use href="#quality-pool-and-spa-dark-icon" /></svg></a>
    <a id="mobile-nav__telephone" href={`tel:${siteConfig.telephone}`} aria-label={`Call Today ${siteConfig.prettyTelephone}`}>
        {siteConfig.prettyTelephone} <svg viewBox="0 0 16 16"><use href="#icon-mobilephone" /></svg>
    </a>
    <input type="checkbox" id="mobile-toggle" hidden aria-hidden="true" />
    <label for="mobile-toggle" id="mobile-hamburger" aria-label="Open Menu">
        <svg viewBox="0 0 24 24"><use href="#icon-hamburger" /></svg>
    </label>
    <div id="mobile-menu-drawer" class="menu-drawer">
        <div class="drawer-header">
            <a href="/">
                <svg class="drawer-logo" viewBox="0 0 1184.82 543.66"><use href="#quality-pool-and-spa-light-logo" /></svg>
            </a>
            <label for="mobile-toggle" id="mobile-menu-close" aria-label="Close Menu">
                <svg viewBox="0 0 95.939 95.939"><use href="#icon-cross" /></svg>
            </label>
        </div>
        <nav class="drawer-nav">
            <ul>
                {
                    links.map((link) => (
                <li><a href={link.href}>{link.icon && <svg viewBox={link.viewBox}><use href={link.icon} /></svg>} {link.name}</a></li>
                    ))
                }
            </ul>
        </nav>
        <div class="drawer-footer">
            <span>&copy; {new Date().getFullYear()} {siteConfig.company}</span>
            <span><a href={`tel:${siteConfig.telephone}`} aria-label={`Call Today ${siteConfig.prettyTelephone}`}>{siteConfig.prettyTelephone}</a></span>
        </div>
    </div>
    <label for="mobile-toggle" id="mobile-menu-overlay" class="menu-overlay"></label>
</div>

<style is:global>
    /* variables context from BaseLayout.astro layout is inherited */

    .mobile-nav-container {
        pointer-events: none; /* Let clicks pass through unless on specific buttons */
    }

    #mobile-nav__telephone {
        pointer-events: auto;
        position: fixed;
        height: 56px;
        top: 7px;
        right: 1cqi;
        z-index: 9999;
        display: inline-flex;
        white-space: nowrap;
        align-items: center;
        justify-content: center;
        padding: 0 1.5cqi;
        font-family: var(--font-roboto-condensed);
        font-weight: 500;
        background: linear-gradient(to right, var(--color-secondary), var(--color-secondary-light));
        color: white;
        text-decoration: none;
        font-size: var(--size-xl);
        text-transform: uppercase;
        transition: color 0.1s ease;
        text-shadow: 1px 1px 0 var(--color-secondary-dark);
        box-shadow: 1px 1px 0 var(--color-secondary-lighter), inset 1px 1px 0 var(--color-secondary-dark);
        border-radius: 15px;
        visibility: hidden;
        opacity: 0;
        transition: background-color 0.1s ease, text-shadow 0.1s ease, box-shadow 0.1s ease;
    }   #mobile-nav__telephone:hover {
        background-color: var(--color-primary);
    }   #mobile-nav__telephone svg {
        display: inline-block;
        width: auto;
        height: 30px;
        filter: drop-shadow(1px 1px 0 var(--color-secondary-dark));
        margin-left: .25rem;
    }

    @media (max-width: 769px) {
        #mobile-nav__telephone {
            height: 36px;
            border-radius: 10px;
        }
    }

    #mobile-hamburger {
        pointer-events: auto;
        position: fixed;
        z-index: 9999;
        width: 56px;
        height: 56px;
        top: 7px;
        left: 1cqi;
        /* background: linear-gradient(to right, var(--color-secondary), var(--color-secondary-light)); */
        /* box-shadow: 1px 1px 0 var(--color-secondary-lighter), inset 1px 1px 0 var(--color-secondary-dark); */
        color: var(--color-primary-dark);
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
    }

    @media (max-width: 769px) {
        #mobile-hamburger {
            width: 36px;
            height: 36px;
        }
    }

    #mobile-nav__icon {
        pointer-events: auto;
        position: fixed;
        z-index: 9999;
        width: 56px;
        height: 56px;
        top: 7px;
        left: 55px;
        color: var(--color-primary-dark);
        border-radius: 50%;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;

        opacity: 0;
        visibility: hidden;
    }

    @media (max-width: 769px) {
        #mobile-nav__icon {
            display: flex;
            width: 36px;
            height: 36px;
            left: 55px;
        }
    }

    #mobile-hamburger.is-visible {
        opacity: 1;
        visibility: visible;
    }

    @media (max-width: 769px) {
        #mobile-hamburger, #mobile-nav__telephone, #mobile-nav__icon {
            opacity: 1;
            visibility: visible;
        }
    }

    /* Menu Drawer Logic */
    #mobile-toggle:checked ~ .menu-drawer {
        transform: translateX(0);
        box-shadow: 10px 0 30px rgba(0, 0, 0, 0.5);
    }

    #mobile-toggle:checked ~ .menu-overlay {
        pointer-events: auto;
        opacity: 1;
        visibility: visible;
    }

    #mobile-toggle:checked ~ .menu-drawer .drawer-nav li {
        opacity: 1;
        transform: translateX(0);
    }

    /* Menu Drawer Styles */

    .menu-drawer {
        container-type: inline-size;
        pointer-events: auto;
        position: fixed;
        top: 0;
        left: 0;
        width: 80vw;
        height: 100dvh;
        z-index: 9999;
        display: flex;
        background-color: var(--color-primary-dark);
        flex-direction: column;
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        transform: translateX(-100%);
        container-type: inline-size;
        overflow-x: hidden;
        overflow-y: auto;
    }

    /* Firefox Fallback */
    @supports (-moz-appearance: none) {
        .menu-drawer {
            scrollbar-width: thin;
            scrollbar-color: var(--color-primary-light) transparent;
        }
	}

    .menu-drawer::-webkit-scrollbar {
        width: 4px;
    }

    .menu-drawer::-webkit-scrollbar-track {
        background: transparent;
    }

    .menu-drawer::-webkit-scrollbar-thumb {
        background: var(--color-primary-light);
        border-radius: 10px;
    }

    .menu-drawer::-webkit-scrollbar-button {
		display: none;
	}

    @media (min-width: 769px) {
        .menu-drawer {
            width: 45vw; /* Increased width for tablet to allow space for large labels */
        }
    }

    @media (min-width: 1200px) {
        .menu-drawer {
            width: 25vw; /* Return to sleek width for large screens */
            max-width: 400px;
        }
    }

    .drawer-header {
        padding: 8cqi;
        position: relative;
    }

    .drawer-logo {
        width: auto;
        height: auto;
        max-height: 100cqi;
        margin: 1rem auto;
    }

    #mobile-menu-close {
        position: absolute;
        top: 1cqi;
        right: 1cqi;
        background: none;
        border: none;
        color: var(--color-accent);
        cursor: pointer;
        padding: 0.5rem;
        transition: transform 0.1s ease;
    }

    #mobile-menu-close:hover {
        transform: rotate(90deg);
    }

    #mobile-menu-close svg {
        width: 5cqi;
        height: 5cqi;
    }

    .drawer-nav {
        flex: 1;
        padding: 0 6cqi;
    }

    .drawer-nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .drawer-nav li {
        margin-bottom: 6cqi;
        opacity: 0;
        transform: translateX(-20cqi);
        transition:
            opacity 0.1s ease,
            transform 1s ease;
    }

    /* Stagger the links */
    .drawer-nav li:nth-child(1) {
        transition-delay: 0.1s;
    }
    .drawer-nav li:nth-child(2) {
        transition-delay: 0.15s;
    }
    .drawer-nav li:nth-child(3) {
        transition-delay: 0.2s;
    }
    .drawer-nav li:nth-child(4) {
        transition-delay: 0.25s;
    }
    .drawer-nav li:nth-child(5) {
        transition-delay: 0.1s;
    }
    .drawer-nav li:nth-child(6) {
        transition-delay: 0.35s;
    }

    .drawer-nav a {
        display: flex;
        align-items: center;
        gap: 3cqi;
        font-family: var(--font-roboto-condensed);
        white-space: nowrap;
        font-size: 8cqi;
        font-weight: 500;
        color: var(--color-foreground-lighter);
        text-decoration: none;
        text-transform: uppercase;
        transition:
            color 0.1s ease,
            padding-left 0.1s ease;
    }

    .drawer-nav a:hover {
        color: var(--color-accent);
        padding-left: 1cqi;
        text-decoration: none;
    }

    .drawer-nav a svg {
        flex-shrink: 0;
        width: 8cqi;
        height: 8cqi;
    }

    .drawer-nav a span {
        flex: 1;
        line-height: 1;
    }

    .drawer-footer {
        display: flex;
        justify-content: space-between;
        padding: 2cqi 1.5cqi;
        border-top: 1px solid var(--color-primary);
    }

    .drawer-footer span {
        font-size: 3cqi;
        color: var(--color-foreground);
        margin: 0;
    }

    .drawer-footer a {
        color: var(--color-foreground);
        text-decoration: none;
        transition: color 0.1s ease;
    }

    .drawer-footer a:hover {
        color: var(--color-accent);
    }

    /* Overlay */
    .menu-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: rgba(0, 0, 0, 0.6);
        z-index: 2050;
        opacity: 0;
        visibility: hidden;
        transition:
            opacity 0.4s ease,
            visibility 0.4s ease;
    }
</style>

<script is:inline>
    function initMobileNav() {
        const toggle = document.getElementById("mobile-toggle");
        const hamburger = document.getElementById("mobile-hamburger");
        const drawer = document.getElementById("mobile-menu-drawer");

        if (!hamburger) return;

        // Body scroll lock
        toggle?.addEventListener("change", () => {
            if (toggle.checked) {
                document.body.style.overflow = "hidden";
            } else {
                document.body.style.overflow = "";
            }
        });

        // Close on swipeLeft (custom event)
        drawer?.addEventListener("swipeLeft", () => {
            if (toggle) toggle.checked = false;
            document.body.style.overflow = "";
        });

        // Interaction Observer for Desktop Sticky Hamburger
        const mainNav =
            document.getElementById("main-nav-observer") ||
            document.getElementById("portal-nav-observer") ||
            document.getElementById("main-nav");

        if (mainNav) {
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (!entry.isIntersecting) {
                            hamburger.classList.add("is-visible");
                            mainNav.classList.add("is-hidden");
                        } else {
                            hamburger.classList.remove("is-visible");
                            mainNav.classList.remove("is-hidden");
                        }
                    });
                },
                {
                    threshold: 0,
                    rootMargin: "-20px 0px 0px 0px",
                },
            );

            observer.observe(mainNav);
        }
    }

    document.addEventListener("DOMContentLoaded", initMobileNav);
    document.addEventListener("astro:page-load", initMobileNav);
</script>
