---
// Assets
import { Image } from "astro:assets";
import { siteConfig } from "../../siteConfig";
// Components
import Button from "../elements/Button.astro";
import Slider from "../elements/Slider.astro";
// Images
import HeroSummerScene from "../../assets/images/summer-hero.webp";
import HeroSummerSceneFuzzy from "../../assets/images/summer-hero-fuzzy.png";
import HeroWinterScene from "../../assets/images/winter-hero.webp";
import HeroWinterSceneFuzzy from "../../assets/images/winter-hero-fuzzy.png";
---

<section id="hero-wrapper">
    <div id="hero" class="summer">
        <div id="hero__image">
            <div class="hero__aspect-wrapper summer-season active fuzzy-load" style={`--background: url('${HeroSummerSceneFuzzy.src}')`}>
                <Image src={HeroSummerScene} alt="Summer Hero" loading="eager" fetchpriority="high" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;" />
                <div id="hero__water"><div class="caustics"></div></div>
            </div>
            <div class="hero__aspect-wrapper winter-season fuzzy-load" style={`--background: url('${HeroWinterSceneFuzzy.src}')`}>
                <Image src={HeroWinterScene} alt="Winter Hero" loading="eager" fetchpriority="high" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;" />
                <div id="hero__water"><div class="caustics"></div></div>
            </div>
        </div>
        <div id="hero__overlay">
            <div id="hero__content">
                <svg id="hero__logo" viewBox="0 0 1006.15 468.32"><use href="#quality-pool-and-spa-stroked-logo" /></svg>
                <Slider autoplay arrows pagination id="hero__slider">
                    <div class="slide">Slide 1</div>
                    <div class="slide">Slide 2</div>
                    <div class="slide">Slide 3</div>
                </Slider>
            </div>
            <div id="hero__side-panel">
                <h2><span>New Customers</span> <span>Receive</span> <span class="fire">20% Off</span> <span>First Service</span></h2>
                <Button href="/contact.html" class="wave">Schedule Now</Button>
                <div id="hero__trust-badges">
                    <a href="#why-choose"><svg viewBox="0 0 813.09 813.09"><use href="#google-reviews-badge" /></svg></a>
                    <a href="https://www.bbb.org/us/ut/south-salt-lake/profile/pool-maintenance/quality-pool-spa-1166-2007823" target="_blank"><svg viewBox="0 0 612.09 741.88"><use href="#bbb-badge" /></svg></a>
                    <svg viewBox="0 0 615.36 597.8"><use href="#utah-local-business-badge" /></svg>
                </div>
                <a id="hero__phone" href={`tel:${siteConfig.telephone}`} aria-label={`Call Today ${siteConfig.prettyTelephone}`}>{siteConfig.prettyTelephone}</a>
            </div>
        </div>
        
    </div>
</section>
<svg width="0" height="0">
    <filter id="water-filter" x="-20%" y="-20%" width="140%" height="140%">
        <feTurbulence id="feTurb" type="fractalNoise" baseFrequency="0.015 0.02" seed="7" numOctaves="2" />
        <feDisplacementMap id="feDisp" in="SourceGraphic" scale="60" />
    </filter>
</svg>

<style is:global>
    #hero-wrapper {
        overflow: hidden;
        padding: 70px 0 0;
    }

    @media (max-width: 769px) {
        #hero-wrapper {
            padding: 50px 0 0;
        }
    }

    #hero {
        width: 100%;
        min-height: calc(90dvh - 70px);
        max-height: 1080px;
        height: 100%;
        margin: 0 auto;
        /* border-radius: 0 0 5cqi 5cqi; */
        background-color: var(--color-primary-light);
        color: var(--color-foreground);
        position: relative;
        overflow: hidden;
        user-select: none;
    }

    @media (max-width: 769px) {
        #hero {
            width: 100%;
            max-height: initial;
            min-height: initial;
            height: initial;
            box-shadow: none;
            border-left:none;
            border-right:none;
            border-bottom:none;
            border-radius: 0;
        }
    }

    #hero__image {
        position: absolute;
        width: 100%;
        height: 100%;
        background-position: center;
        container-type: size;
        overflow: hidden;

    }

    @media (max-width: 769px) {
        #hero__image {
            height: 400px;
        }
    }

    .hero__aspect-wrapper {
        display: block !important;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: max(100cqw, 100cqh * 2.37) !important;
        height: max(100cqh, 100cqw / 2.37) !important;
        transition: opacity .5s ease-in-out;
    }

    .hero__aspect-wrapper > img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        position: absolute;
        top: 0;
        left: 0;
    }

    #hero__water {
        width: 100%;
        height: 100%;
        position: absolute;
        top: 0;
        left: 0;
        clip-path: polygon(
            0% 100%,
            100% 100%,
            100% 80%,
            calc(50% + 18%) 58%,
            calc(50% - 20%) 58%,
            0% 80%
        );
        z-index: 5;
        overflow: hidden;
        filter: url(#water-filter);
        transform: translateZ(0);
    }

    .caustics {
        position: absolute;
        top: 0;
        left: 0;
        width: calc(100% + 600px);
        height: calc(100% + 450px);
        background-image: url(/images/caustics.webp);
        background-size: 600px auto;
        background-repeat: repeat;
        transform-origin: center center;
        opacity: 0.4;
        animation: move-water 30s linear infinite;
        will-change: transform;
    }

    @media (max-width: 769px) {
        .caustics {
            width: calc(100% + 400px);
            height: calc(100% + 300px);
            background-size: 400px auto;
            animation: move-water-mobile 20s linear infinite;
        }
    }

    @keyframes move-water {
        from { transform: translate3d(0, 0, 0); }
        to { transform: translate3d(-600px, -450px, 0); }
    }

    @keyframes move-water-mobile {
        from { transform: translate3d(0, 0, 0); }
        to { transform: translate3d(-400px, -300px, 0); }
    }

    #hero__logo {
        display: block;
        position: absolute;
        top: 2%;
        left: 50%;
        --logo-tx: -50%;
        transform: translateX(var(--logo-tx)) scale(0.6);
        opacity: 0;
        height: 40%;
        width: auto;
        max-width: 80%;
        /* filter:  drop-shadow(.1cqi .1cqi rgba(255, 255, 255, .6)) drop-shadow(.3cqi .3cqi 0 rgba(10, 80, 129, 0.3)); */
    }

    @media (max-width: 769px) {
        #hero__logo {
            position: static;
            --logo-tx: 0;
            transform: translateX(var(--logo-tx));
            max-width: 90%;
            height: auto;
            max-height: 200px;
            margin: 0 auto;
            /* filter:  drop-shadow(2px 2px 0 rgba(255, 255, 255, .6)) drop-shadow(4px 4px 0 rgba(10, 80, 129, 0.3)); */
        }
    }

    @media (prefers-reduced-motion: no-preference) {
        #hero__logo {
            animation: logo-pop-in 1.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
            animation-delay: 0.1s;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        #hero__logo {
            opacity: 1;
            transform: translateX(var(--logo-tx)) scale(1);
        }
    }

    @keyframes logo-pop-in {
        0% { opacity: 0; transform: translateX(var(--logo-tx)) scale(0.6); }
        100% { opacity: 1; transform: translateX(var(--logo-tx)) scale(1); }
    }

    #hero__slider {
        width: 100%;
        height: 100%;
    }

    #hero__slider .slide {
        height: 50%;
        top: 50%;
        padding: 0 calc(70px + 2rem) 2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;

        font-size: 5cqi;
        font-weight: bold;
        color: var(--color-foreground-lighter);
        text-shadow: 0 3px 0 rgba(0, 0, 0, 0.2);


    }

    @media (max-width: 769px) {
        #hero__slider .slide {
            height: 100%;
            top: 0;
            padding: 3.5cqi;
        }
    }

    #hero__overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 5;
        box-shadow: inset 0 3px 0 rgba(0, 0, 0, 0.2);
    }

    @media (max-width: 769px) {
        #hero__overlay {
            position: relative;
            width: 100%;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }
    }

    #hero__content {
        height: 100%;
        width: 75%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        background-image: url(/images/hero-desktop.svg);
        background-position: right center;
        background-repeat: no-repeat;
        background-size: contain;
    }

    @media (max-width: 769px) {
        #hero__content {
            height: 400px;
            padding-top: 2cqi;
            width: 100%;
            background-image: none;
            border-bottom: solid 3px var(--color-secondary);
        }
    }

    #hero__side-panel {
        container-type: inline-size;
        height: 100%;
        width: 25%;
        overflow: hidden;
        padding: 0 2cqi;
        background-color: rgba(6, 81, 129, 0.8);
        z-index: 5;
        color: var(--color-foreground-lighter);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
    #hero__side-panel h2 {
        text-align: right;
        font-size: 14.25cqi;
        word-spacing: 0px;
        text-indent: 0px;
        margin-bottom: 10cqi;
        color: var(--color-foreground-lighter);
        text-shadow: 0 3px 0 rgba(0, 0, 0, 0.3);
    }
    #hero__side-panel h2 span {
        position: relative;
        display: block;
        white-space: nowrap;
        line-height: .875em;
        margin-bottom: 0;
        opacity: 0;
        transform: translateX(110%);
    }

    @media (max-width: 769px) {
        #hero__side-panel {
            width: 100%;
            height: auto;
            background-color: var(--color-primary);
            padding: 1rem 5cqi 0;
            box-shadow: inset 0 3px 0 rgba(0, 0, 0, 0.2);
        }
        #hero__side-panel h2 {
            text-align: center;
            scale: 0.8;
            margin-bottom: 0;
        }
    }
    
    @media (prefers-reduced-motion: no-preference) {
        .fonts-loaded #hero__side-panel h2 span {
            animation: slide-in-bounce 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }
        .fonts-loaded #hero__side-panel h2 span:nth-child(1) { animation-delay: 0.1s; }
        .fonts-loaded #hero__side-panel h2 span:nth-child(2) { animation-delay: 0.2s; }
        .fonts-loaded #hero__side-panel h2 span:nth-child(3) { animation-delay: 0.1s; }
        .fonts-loaded #hero__side-panel h2 span:nth-child(4) { animation-delay: 0.4s; }
    }

    @media (prefers-reduced-motion: reduce) {
        #hero__side-panel h2 span {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @keyframes slide-in-bounce {
        0% { opacity: 0; transform: translateX(110%); }
        100% { opacity: 1; transform: translateX(0); }
    }

    #hero__side-panel h2 span.fire {
        text-shadow: none;
    }

    #hero__side-panel h2 span:nth-child(1) {
        font-family: var(--font-roboto-condensed);
        font-weight: 900;
        letter-spacing: -.35cqi;
    }
    #hero__side-panel h2 span:nth-child(2) {
        font-size: 25cqi;
        letter-spacing: -.5cqi;
    }
    #hero__side-panel h2 span:nth-child(3) {
        font-family: var(--font-roboto-condensed);
        font-weight: 900;
        font-size: 30cqi;
    }
    #hero__side-panel h2 span:nth-child(4) {
        word-spacing: 4cqi;
    }

    #hero__trust-badges {
        display: flex;
        gap: 10cqi;
        align-items: center;
        margin-top: 10cqi;
    }

    #hero__trust-badges svg {
        width: 20cqi;
        height: auto;
        object-fit: contain;
        filter: drop-shadow(5px 5px 0 rgba(4, 31, 50, 0.3));
    }

    @media (max-width: 769px) {
        #hero__trust-badges { gap: 8cqi; margin-bottom: 10cqi;}
        #hero__trust-badges svg { width: 18cqi; }
    }

    #hero__phone {
        display: block;
        margin-top: 10cqi;
        font-size: 14cqi;
        white-space: nowrap;
        letter-spacing: -.5cqi;
        font-family: var(--font-roboto-condensed);
        font-weight: 900;
        color: var(--color-foreground-lighter);
        text-decoration: none;
        text-shadow: 0 3px 0 rgba(0, 0, 0, 0.3);
    }

    @media (max-width: 769px) {
        #hero__phone { display: none; }
    }
</style>
